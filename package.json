{
  "name": "showtime",
  "productName": "Showtime",
  "version": "0.1.0",
  "description": "Showtime — SNL Day Planner for ADHD-friendly task management with Claude Code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vishnujayvel/showtime.git"
  },
  "bugs": {
    "url": "https://github.com/vishnujayvel/showtime/issues"
  },
  "homepage": "https://github.com/vishnujayvel/showtime#readme",
  "main": "dist/main/index.js",
  "scripts": {
    "pretest": "npm rebuild better-sqlite3 --silent 2>/dev/null || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "npx electron-rebuild -f -w better-sqlite3 --silent 2>/dev/null || true",
    "test:e2e": "npx playwright test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test:e2e:smoke": "npx playwright test --project=smoke",
    "test:e2e:tail": "tail -f test-results/e2e-progress.log",
    "pretest:e2e:report": "cp -r allure-report/history allure-results/history 2>/dev/null || true",
    "test:e2e:report": "allure generate allure-results --clean -o allure-report && echo '✔ Report generated at allure-report/index.html'",
    "test:e2e:report:open": "allure open allure-report",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "lint:docs": "npx tsx scripts/lint-docs.ts",
    "preview": "electron-vite preview",
    "dist": "electron-vite build --mode production && electron-builder --mac --dir",
    "doctor": "bash scripts/doctor.sh",
    "postinstall": "electron-builder install-app-deps && bash scripts/patch-dev-icon.sh",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@vitest/coverage-v8": "^4.1.2",
    "@xstate/react": "^6.1.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.35.1",
    "lucide-react": "^1.7.0",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "xstate": "^5.30.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.showtime.app",
    "productName": "Showtime",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "resources/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Showtime uses your microphone to transcribe voice input locally with Whisper."
      }
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@statelyai/inspect": "^0.4.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xstate/graph": "^3.0.4",
    "allure-playwright": "^3.6.0",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "eslint": "^10.2.0",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
